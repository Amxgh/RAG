WAAM_RAG_CONFIG_PATH=config/settings.example.yaml
WAAM_RAG_STORAGE_DIR=data
WAAM_RAG_UPLOADS_DIR=data/uploads
WAAM_RAG_LOG_LEVEL=INFO
WAAM_RAG_LOG_JSON=true
WAAM_RAG_VECTOR_BACKEND=sqlite_local
WAAM_RAG_EMBEDDING_BACKEND=hashing
WAAM_RAG_EMBEDDING_MODEL=intfloat/e5-base-v2
WAAM_RAG_RERANKER_ENABLED=false
WAAM_RAG_BM25_ENABLED=true
WAAM_RAG_CHUNK_SIZE_TOKENS=700
WAAM_RAG_CHUNK_OVERLAP_TOKENS=120
WAAM_RAG_TOP_K=8
WAAM_RAG_RETRIEVE_CANDIDATES=24
WAAM_RAG_EXCLUDE_REFERENCES=true
WAAM_RAG_ENABLE_OCR_FALLBACK=false
WAAM_RAG_QUERY_EXPANSION_ENABLED=true
WAAM_RAG_CITATION_STYLE=author_year_pages
WAAM_RAG_OPEN_WEBUI_BASE_URL=http://host.docker.internal:3000
WAAM_RAG_OPEN_WEBUI_MODEL=deepseek-r1:8b
WAAM_RAG_FORWARD_RESULTS_TO_OPEN_WEBUI=false
